# Copy this file to .env and fill in your values

# ─── MySQL Database ────────────────────────────────────────────────────────────
# Format: username:password@tcp(host:port)/database_name?parseTime=true
MYSQL_DSN=root:yourpassword@tcp(127.0.0.1:3306)/resumind?parseTime=true

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create a project → Enable "Google Identity" API
# 2. Create OAuth 2.0 Client ID (Web Application)
# 3. Add Authorized JavaScript origins: http://localhost:5173
# 4. Add Authorized redirect URIs: http://localhost:5173/auth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Groq AI API ──────────────────────────────────────────────────────────────
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── JWT Security ─────────────────────────────────────────────────────────────
# Replace with a long random secret string (min 32 characters)
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-string-here

# ─── Server Config ────────────────────────────────────────────────────────────
PORT=8080
UPLOADS_DIR=./uploads
